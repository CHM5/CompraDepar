# ─────────────────────────────────────────────────────────────────────────────
# Depar Finder — Frontend env vars
# Copiá este archivo a .env.local y completá los valores.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend URL (dejar vacío para usar http://localhost:8000 en local) ────────
# NEXT_PUBLIC_API_URL=https://tu-backend.railway.app

# ── Google Sheets (para el link directo en el menú) ───────────────────────────
# NEXT_PUBLIC_SHEETS_ID=1FxQJU8iR_31B8b5Y0bdP0PAxbw7AEObVbengyEQ5Gfk

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Obtené estos valores en Firebase Console → Project Settings → General → Your apps
# Si no configurás Firebase, la app funciona en "modo demo" con auth simulada.
#
# NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
# NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Admin emails (comma-separated) ────────────────────────────────────────────
# Estos usuarios obtienen plan Premium automáticamente y acceso admin.
# NEXT_PUBLIC_ADMIN_EMAILS=hernán@gmail.com,otro@gmail.com
